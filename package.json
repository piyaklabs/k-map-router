{
  "name": "k-map-router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "selftest": "node resolve-test.mjs --selftest",
    "verify:deployed": "node verify-deployed.mjs"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
